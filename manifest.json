{
  "manifest_version": 3,
  "name": "Acessibilidade+",
  "version": "1.2",
  "description": "Ferramentas de acessibilidade: zoom, contraste, dislexia, leitura, foco.",
  "permissions": [
    "activeTab",
    "scripting",
    "tts",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}